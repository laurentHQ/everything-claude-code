      "targets": ["claude", "codex", "opencode"],
      "settings": {
        "hook_profile": "standard",
        "allow_mcp": false,
        "require_dry_run_first": true,
        "lifecycle": "draft"
      }
    },
    "full": {
      "description": "Complete ECC install with all currently classified modules.",
      "modules": [
        "rules-core",
        "agents-core",
        "commands-core",
