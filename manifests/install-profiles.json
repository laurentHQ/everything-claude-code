        "agents-core",
        "commands-core",
        "hooks-runtime",
        "platform-configs",
        "workflow-quality",
        "security"
      ],
      "targets": ["claude", "codex", "opencode"],
      "settings": {
        "hook_profile": "strict",
        "block_global_install": true,
        "allow_mcp": false,
        "require_audit_log": true,
        "require_dry_run_first": true,
        "lifecycle": "draft"
      }
