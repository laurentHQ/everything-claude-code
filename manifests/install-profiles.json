        "agents-core",
        "commands-core",
        "hooks-runtime",
        "platform-configs",
        "workflow-quality",
        "security"
      ],
      "targets": ["claude", "codex"],
      "settings": {
        "hook_profile": "strict",
        "require_audit_log": true,
        "allow_mcp": true,
        "allowed_mcp_servers": ["context7", "github"],
        "write_scope": "controlled",
        "block_global_install": false,
        "require_dry_run_first": true,
