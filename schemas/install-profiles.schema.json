{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ECC Install Profiles",
  "type": "object",
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "profiles": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "pattern": "^[a-z0-9-]+$"
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "description": {
            "type": "string",
            "minLength": 1
          },
          "modules": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9-]+$"
            }
          },
          "targets": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "enum": [
                "claude",
                "codex",
                "opencode",
                "cursor",
                "antigravity",
                "gemini",
                "codebuddy",
                "joycode",
                "qwen"
              ]
            }
          },
          "settings": {
            "type": "object",
            "properties": {
              "scope": {
                "type": "string",
                "enum": ["project", "user", "sandbox"]
              },
              "hook_profile": {
                "type": "string",
                "enum": ["none", "standard", "strict", "validation"]
              },
              "allow_mcp": {
                "type": "boolean"
              },
              "allowed_mcp_servers": {
                "type": "array",
                "default": [],
                "items": {
                  "type": "string",
                  "pattern": "^[a-z0-9_-]+$"
                }
              },
              "require_dry_run_first": {
                "type": "boolean"
              },
              "require_audit_log": {
                "type": "boolean"
              },
              "block_global_install": {
                "type": "boolean"
              },
              "write_scope": {
                "type": "string",
                "enum": ["project-only", "project-local", "controlled"]
              },
              "lifecycle": {
                "type": "string",
                "enum": ["draft", "candidate", "promoted"]
              }
            },
            "additionalProperties": false
          }
        },
        "required": [
          "description",
          "modules"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "version",
    "profiles"
  ],
  "additionalProperties": false
}
